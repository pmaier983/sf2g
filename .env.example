# Strava OAuth
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
APP_URL=http://localhost:5173
SESSION_SECRET=a-random-32-character-string-for-cookie-signing

# Strava Webhooks
STRAVA_WEBHOOK_VERIFY_TOKEN=a-random-string-for-webhook-verification

# Optional
NODE_ENV=development

# PostHog Analytics (optional — analytics disabled if not set)
# Requests are proxied through /ingest to bypass ad blockers (see app/ssr.tsx)
VITE_POSTHOG_KEY=your_posthog_project_api_key
